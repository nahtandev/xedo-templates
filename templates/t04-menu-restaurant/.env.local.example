# ──────────────────────────────────────────────────────────────────────
# Variables d'environnement — copier ce fichier vers .env.local puis
# renseigner les valeurs. NE JAMAIS commiter .env.local.
# Toutes les variables lues par l'app sont déclarées ici (voir lib/env.ts).
# ──────────────────────────────────────────────────────────────────────

# [Requis] Clé API Xedo (xdk_live_… ou xdk_test_…).
# À obtenir sur business.xedoapp.com > Clés API. Côté serveur uniquement —
# ne jamais l'exposer au navigateur ni la logger.
XEDO_API_KEY=xdk_live_...

# [Requis] URL publique du site, utilisée comme returnUrl après le paiement.
# Doit être en HTTPS en production (exigé par l'API Xedo). En dev : localhost.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# [Optionnel] Override de l'URL de base de l'API Xedo (testnet vs prod).
# Laisser commenté pour utiliser l'URL de production par défaut du SDK.
XEDO_API_BASE_URL=https://systems.xedotestnet.space/marketplace
